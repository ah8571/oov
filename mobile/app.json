{
  "expo": {
    "name": "Emmaline",
    "slug": "emmaline",
    "version": "0.1.0",
    "icon": "./assets/white-outline-favicon.png",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./assets/white-outline-favicon.png",
      "bundleIdentifier": "com.emmaline.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Emmaline needs microphone access so you can talk to your AI assistant during in-app calls.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "splash": {
      "image": "./assets/white-outline-favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/white-outline-favicon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.emmaline.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-dev-client",
      "./plugins/withTwilioVoiceApplicationProxy"
    ],
    "extra": {
      "eas": {
        "projectId": "fc34b757-3492-45c6-8517-ed22abab10a1"
      }
    }
  }
}
