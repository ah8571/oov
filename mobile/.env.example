# Mobile API endpoint used by Expo app
# Recommended for MVP phone testing: custom domain (SSL enabled)
EXPO_PUBLIC_API_URL=https://api.oov.digital/api

# RevenueCat public SDK keys
# iOS key format usually begins with appl_
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
# Android/Google key format usually begins with goog_
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=

# Alternate DigitalOcean default app domain
# EXPO_PUBLIC_API_URL=https://emmaline-agtyz.ondigitalocean.app/api

# Optional local backend testing (replace with your computer LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.25:3000/api

# --- AppsFlyer & SKAdNetwork (SKAN) configuration ---
# AppsFlyer dev key (example placeholder). Use EAS secrets for production values.
# APPSFLYER_DEV_KEY=vTneNhwfK35XFh3dEKBay5

# App Store numeric ID (used by AppsFlyer / Expo)
# EXPO_IOS_APP_ID=6783906612

# SKAdNetwork IDs (comma or newline separated). Replace with IDs from AppsFlyer or ad partners.
# Only include the networks you plan to run campaigns with to avoid bloating Info.plist.
# Example:
# EXPO_PUBLIC_IOS_SKADNETWORK_IDS=2fnua5tdw4.skadnetwork,3rd_party_id,4fzdc2evr5.skadnetwork

# Notes:
# - Preferred: Use `eas secret:create --name EXPO_PUBLIC_IOS_SKADNETWORK_IDS --value "id1,id2,..."`
#   to inject SKAN IDs at build-time rather than committing them to the repo.
# - AppsFlyer: use the SKAN Conversion Studio to map in-app events (Registration, Session, Subscribe)
#   to fine/coarse conversion values. Ensure the app calls `appsFlyer.logEvent(...)` for those events.
