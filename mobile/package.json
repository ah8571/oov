{
  "name": "emmaline-mobile",
  "version": "0.1.0",
  "description": "React Native app for Emmaline AI Phone Call Buddy",
  "main": "index.js",
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface",
          "@twilio/voice-react-native-sdk"
        ]
      },
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface",
          "@twilio/voice-react-native-sdk"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^15.0.1",
    "@expo/vector-icons": "15.0.3",
    "@react-navigation/bottom-tabs": "^6.5.10",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.18",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.38.0",
    "@twilio/voice-react-native-sdk": "^1.7.0",
    "axios": "^1.6.0",
    "buffer": "^6.0.3",
    "expo": "^57.0.6",
    "expo-apple-authentication": "~57.0.1",
    "expo-application": "~57.0.1",
    "expo-asset": "~57.0.5",
    "expo-audio": "~57.0.2",
    "expo-auth-session": "~57.0.3",
    "expo-av": "~16.0.8",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.6",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.5",
    "expo-speech": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-appsflyer": "^6.18.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-purchases": "^10.4.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "13.16.1",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@types/react": "~19.2.4",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "typescript": "~6.0.3"
  }
}
