{
  "name": "emmaline-mobile",
  "version": "0.1.0",
  "description": "React Native app for Emmaline AI Phone Call Buddy",
  "main": "index.js",
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      },
      "android": {
        "exclude": [
          "expo-dev-client",
          "expo-dev-launcher",
          "expo-dev-menu",
          "expo-dev-menu-interface"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@expo/vector-icons": "15.0.3",
    "@react-navigation/bottom-tabs": "^6.5.10",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.18",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.38.0",
    "@twilio/voice-react-native-sdk": "^1.7.0",
    "axios": "^1.6.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-appsflyer": "^6.18.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-purchases": "^10.4.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "zustand": "^4.4.6"
  },
  "overrides": {
    "expo-font": "~14.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@types/react": "~19.1.10",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "typescript": "~5.9.2"
  }
}
